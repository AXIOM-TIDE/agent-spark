# AgentSpark Environment Variables
# Copy this to .env and fill in your values

# Your Coinbase Wallet address (0x...) — this receives all fees
PLATFORM_WALLET=0xYourWalletAddressHere

# Supabase project URL and anon key
# Get these from: https://supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Network
# Testnet (safe for testing):  eip155:84532
# Mainnet (real money):        eip155:8453
NETWORK=eip155:84532

# Port (optional, defaults to 4021)
PORT=4021
